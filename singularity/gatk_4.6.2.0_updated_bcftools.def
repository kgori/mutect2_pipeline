Bootstrap: docker
From: broadinstitute/gatk:4.6.2.0

%help
    GATK 4.6.2.0 with updated bcftools 1.22 and bwa-mem2

%post
    apt-get update && apt-get install -y \
        autoconf \
        automake \
        libcurl4-openssl-dev \
        libssl-dev \
        zlib1g-dev \
        libbz2-dev \
        liblzma-dev \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    cd /opt && \
    git clone --recurse-submodules --branch 1.22 https://github.com/samtools/htslib.git
    git clone --recurse-submodules --branch 1.22 https://github.com/samtools/bcftools.git
    git clone --recurse-submodules --branch v2.3 https://github.com/bwa-mem2/bwa-mem2.git

    cd /opt/htslib && \
    autoreconf -i && \
    CC=/usr/bin/gcc CXX=/usr/bin/g++ ./configure --prefix=/ --enable-libcurl
    make && make install

    cd /opt/bcftools && \
    autoreconf -i && \
    CC=/usr/bin/gcc CXX=/usr/bin/g++ ./configure --prefix=/
    make && make install

    cd /opt/bwa-mem2 && \
    CC=/usr/bin/gcc CXX=/usr/bin/g++ make && \
    mv bwa-mem2* /usr/bin

    rm -rf /opt/htslib /opt/bcftools /opt/bwa-mem2
